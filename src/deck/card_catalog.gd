static func load_default() -> Dictionary:
	var registry = DeckRulesRegistryClass.load_default()
	if not registry.is_ready():
		return {
			"error": "Failed to load deck rules registry: %s" % registry.get_load_error(),
			"cards": [],
			"card_by_id": {},
		}

	var cards: Array = []
	var card_by_id := {}
	var deck_code_to_card_id := {}
	var card_id_to_deck_code := {}
	for raw_seed in _card_seeds():
		if typeof(raw_seed) != TYPE_DICTIONARY:
			continue
		var card := _build_card(raw_seed, registry)
		cards.append(card)
		var cid: String = str(card.get("card_id", ""))
		card_by_id[cid] = card
		var dcode = card.get("deck_code_id")
		if dcode != null and dcode is String and not dcode.is_empty():
			deck_code_to_card_id[dcode] = cid
			card_id_to_deck_code[cid] = dcode
	return {
		"error": "",
		"cards": cards,
		"card_by_id": card_by_id,
		"deck_code_to_card_id": deck_code_to_card_id,
		"card_id_to_deck_code": card_id_to_deck_code,
	}


static func _build_card(seed: Dictionary, registry) -> Dictionary:
	var attributes: Array = registry.normalize_attribute_ids(seed.get("attributes", []))
	var class_id: Variant = null
	if attributes.size() >= 2:
		class_id = registry.get_class_for_attributes(attributes).get("id", null)
	var card := {
		"card_id": str(seed.get("card_id", "")),
		"name": str(seed.get("name", "")),
		"card_type": str(seed.get("card_type", "creature")),
		"subtypes": seed.get("subtypes", []).duplicate(true),
		"attributes": attributes,
		"class_id": class_id,
		"rarity": str(seed.get("rarity", "common")),
		"is_unique": bool(seed.get("is_unique", false)),
		"cost": int(seed.get("cost", 0)),
		"base_power": int(seed.get("base_power", 0)),
		"base_health": int(seed.get("base_health", 0)),
		"keywords": seed.get("keywords", []).duplicate(true),
		"effect_ids": seed.get("effect_ids", []).duplicate(true),
		"rules_text": str(seed.get("rules_text", "")),
		"rules_tags": seed.get("rules_tags", []).duplicate(true),
		"support_uses": int(seed.get("support_uses", 0)),
		"set_id": str(seed.get("set_id", DEFAULT_SET_ID)),
		"release_group_id": str(seed.get("release_group_id", DEFAULT_RELEASE_GROUP_ID)),
		"collectible": seed.get("collectible", true),
		"generated_by_rules": false,
		"source_ids": ["uesp_core_set"],
		"art_path": str(seed.get("art_path", "res://assets/images/cards/" + str(seed.get("card_id", "")) + ".png")),
		"deck_code_id": seed.get("deck_code_id", null),
	}
	if str(seed.get("card_type", "")) == "item":
		card["equip_power_bonus"] = int(seed.get("equip_power_bonus", 0))
		card["equip_health_bonus"] = int(seed.get("equip_health_bonus", 0))
		card["equip_keywords"] = seed.get("equip_keywords", []).duplicate(true)
	var action_target_mode := str(seed.get("action_target_mode", ""))
	if not action_target_mode.is_empty():
		card["action_target_mode"] = action_target_mode
	var triggered: Array = seed.get("triggered_abilities", [])
	if not triggered.is_empty():
		card["triggered_abilities"] = triggered.duplicate(true)
	if seed.has("aura"):
		card["aura"] = seed["aura"].duplicate(true)
	if seed.has("grants_immunity"):
		card["grants_immunity"] = seed["grants_immunity"].duplicate(true)
	if seed.has("grants_trigger"):
		card["grants_trigger"] = seed["grants_trigger"].duplicate(true)
	if seed.has("cost_reduction_aura"):
		card["cost_reduction_aura"] = seed["cost_reduction_aura"].duplicate(true)
	if seed.has("cost_increase_aura"):
		card["cost_increase_aura"] = seed["cost_increase_aura"].duplicate(true)
	if seed.has("play_limit_per_turn"):
		card["play_limit_per_turn"] = int(seed["play_limit_per_turn"])
	if seed.has("magicka_aura"):
		card["magicka_aura"] = int(seed["magicka_aura"])
	if seed.has("shout_chain_id"):
		card["shout_chain_id"] = str(seed["shout_chain_id"])
	if seed.has("shout_level"):
		card["shout_level"] = int(seed["shout_level"])
	if seed.has("shout_levels"):
		card["shout_levels"] = seed["shout_levels"].duplicate(true)
	if seed.has("innate_statuses"):
		card["innate_statuses"] = seed["innate_statuses"].duplicate(true)
	if seed.has("self_immunity"):
		card["self_immunity"] = seed["self_immunity"].duplicate(true)
	if seed.has("first_turn_hand_cost"):
		card["first_turn_hand_cost"] = int(seed["first_turn_hand_cost"])
	if seed.has("self_cost_reduction"):
		card["self_cost_reduction"] = seed["self_cost_reduction"].duplicate(true)
	if seed.has("play_condition"):
		card["play_condition"] = seed["play_condition"].duplicate(true)
	if seed.has("passive_abilities"):
		card["passive_abilities"] = seed["passive_abilities"].duplicate(true)
	if seed.has("attack_condition"):
		card["attack_condition"] = seed["attack_condition"].duplicate(true)
	if seed.has("_empower_target_bonus"):
		card["_empower_target_bonus"] = int(seed["_empower_target_bonus"])
	return card


